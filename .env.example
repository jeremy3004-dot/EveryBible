# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (optional, for Google Sign-In)
# Create at: https://console.cloud.google.com/apis/credentials
# Android uses the web client ID for Supabase token exchange in this app.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Bible.is Audio API (optional, only for future Bible.is-backed translations)
# Register at: https://www.faithcomesbyhearing.com/bible-brain/developer-documentation
EXPO_PUBLIC_BIBLE_IS_API_KEY=your-bible-is-api-key
EXPO_PUBLIC_CONTENT_API_URL=https://everybible.app/api/mobile/content

# Web platform public runtime
# Used by apps/site and apps/admin once the web workstream is active
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SITE_URL=https://everybible.app
NEXT_PUBLIC_ADMIN_URL=https://admin.everybible.app

# Web/admin server-only secrets
# Never expose these to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
EVERYBIBLE_UPSTREAM_API_BASE_URL=https://api.example.com
EVERYBIBLE_UPSTREAM_API_KEY=your-upstream-api-key
