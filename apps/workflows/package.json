{
  "name": "@everybible/workflows",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "trigger dev --config trigger.config.ts --env-file ../../.env",
    "deploy:dry-run": "CI=1 trigger deploy . --env staging --dry-run --env-file ../../.env",
    "deploy:staging": "CI=1 trigger deploy . --env staging --env-file ../../.env",
    "deploy:prod": "CI=1 trigger deploy . --env prod --env-file ../../.env",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@everybible/langquest-ingest": "file:../../packages/langquest-ingest",
    "@aws-sdk/client-s3": "^3.1022.0",
    "@trigger.dev/sdk": "^4.4.5",
    "@supabase/supabase-js": "^2.91.0"
  },
  "devDependencies": {
    "trigger.dev": "^4.4.5",
    "typescript": "~5.9.2"
  }
}
