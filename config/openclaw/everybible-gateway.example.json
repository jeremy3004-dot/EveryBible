{
  // EveryBible OpenClaw gateway example for OpenClaw 2026.4.1.
  // OpenClaw reads JSON5 even though the config file is named .json.

  gateway: {
    mode: "local",
    port: 18789,
    bind: "loopback",
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  plugins: {
    enabled: true,

    // Keep local recall/capture on the built-in long-term memory engine.
    // Honcho is optional and can be enabled later without changing the slot.
    slots: {
      memory: "memory-lancedb",
    },

    entries: {
      everybible: {
        enabled: true,
      },

      acpx: {
        enabled: true,
      },

      "openclaw-honcho": {
        // Optional. Leave disabled until you have run `openclaw honcho setup`
        // and you want Honcho's service-backed cross-session memory layer too.
        enabled: false,
        config: {
          workspaceId: "openclaw",
          baseUrl: "${HONCHO_BASE_URL}",
          apiKey: "${HONCHO_API_KEY}",
        },
      },
    },
  },

  models: {
    providers: {
      openai: {
        apiKey: "${OPENAI_API_KEY}",
        baseUrl: "https://api.openai.com/v1",
      },
    },
  },

  agents: {
    defaults: {
      model: {
        primary: "openai/gpt-5.4",
      },
    },
  },

  acp: {
    enabled: true,
    dispatch: {
      enabled: true,
    },
    backend: "acpx",
    defaultAgent: "codex",
    allowedAgents: ["codex"],
    maxConcurrentSessions: 4,
    stream: {
      coalesceIdleMs: 300,
      maxChunkChars: 1200,
    },
    runtime: {
      ttlMinutes: 120,
    },
  },

  channels: {
    telegram: {
      enabled: true,
      botToken: "${EVERYBIBLE_OPERATOR_TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      allowFrom: [
        "${EVERYBIBLE_OPERATOR_TELEGRAM_ALLOW_FROM}",
      ],
      // Keep groups off for the MVP. If you later need Telegram forum topics
      // for ACP thread binding, add a groups block and enable topic routing.
      groupPolicy: "disabled",
    },
  },
}
