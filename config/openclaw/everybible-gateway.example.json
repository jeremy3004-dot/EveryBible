{
  // EveryBible OpenClaw gateway example for OpenClaw 2026.4.1.
  // OpenClaw reads JSON5 even though the config file is named .json.

  gateway: {
    mode: "local",
    port: 18791,
    bind: "loopback",
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  plugins: {
    enabled: true,

    entries: {
      everybible: {
        enabled: true,
      },

      acpx: {
        enabled: true,
      },

      "openclaw-honcho": {
        // Optional. Leave disabled until you have run `openclaw honcho setup`
        // and you want service-backed cross-session memory beyond the bundled
        // file-backed memory-core baseline.
        enabled: false,
        config: {
          workspaceId: "openclaw",
          baseUrl: "${HONCHO_BASE_URL}",
          apiKey: "${HONCHO_API_KEY}",
        },
      },
    },
  },

  models: {
    providers: {
      openai: {
        apiKey: "${OPENAI_API_KEY}",
        baseUrl: "https://api.openai.com/v1",
      },
    },
  },

  agents: {
    defaults: {
      model: {
        // If you are reusing local Codex OAuth instead of OPENAI_API_KEY, set
        // EVERYBIBLE_OPERATOR_MODEL_ID to openai-codex/gpt-5.4 in the host config.
        primary: "${EVERYBIBLE_OPERATOR_MODEL_ID}",
      },
    },
  },

  acp: {
    enabled: true,
    dispatch: {
      enabled: true,
    },
    backend: "acpx",
    defaultAgent: "codex",
    allowedAgents: ["codex"],
    maxConcurrentSessions: 4,
    stream: {
      coalesceIdleMs: 300,
      maxChunkChars: 1200,
    },
    runtime: {
      ttlMinutes: 120,
    },
  },

  channels: {
    telegram: {
      enabled: true,
      botToken: "${EVERYBIBLE_OPERATOR_TELEGRAM_BOT_TOKEN}",
      dmPolicy: "allowlist",
      allowFrom: [
        "${EVERYBIBLE_OPERATOR_TELEGRAM_ALLOW_FROM}",
      ],
      // Use pairing only for first contact if you still need to discover the
      // numeric Telegram sender ID, then move back to allowlist immediately.
      // Keep groups off for the MVP. If you later need Telegram forum topics
      // for ACP thread binding, add a groups block and enable topic routing.
      groupPolicy: "disabled",
    },
  },
}
